<?xml version="1.0" encoding="UTF-8"?>
<types xmlns:sbe="http://fixprotocol.io/2016/sbe">
    <enum name="SideEnum" encodingType="uint8">
        <validValue name="Buy">0</validValue>
        <validValue name="Sell">1</validValue>
    </enum>
    <enum name="TypeEnum" encodingType="uint8">
        <validValue name="Limit">0</validValue>
        <validValue name="Market">1</validValue>
    </enum>
    <enum name="ActionEnum" encodingType="uint8">
        <validValue name="Create">0</validValue>
        <validValue name="Modify">1</validValue>
        <validValue name="Cancel">2</validValue>
    </enum>


        <composite name="messageHeader" description="Message identifiers">
            <type name="blockLength" primitiveType="uint16"/>
            <type name="templateId"  primitiveType="uint16"/>
            <type name="schemaId"    primitiveType="uint16"/>
            <type name="version"     primitiveType="uint16"/>
        </composite>
</types>
